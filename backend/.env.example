MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mouser?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
PORT=5000

# Email (nodemailer) settings - used for order notifications
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password

# URL of the frontend (set this to your Vercel/Netlify/hosted frontend origin in production)
FRONTEND_URL=https://your-frontend-domain.com