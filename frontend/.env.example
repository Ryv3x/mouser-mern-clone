# Frontend environment variables for Vite
# Set VITE_API_URL to your backend origin (do NOT include trailing /api)
# Example for deployed backend on Render/Railway: https://api-yourapp.onrender.com

VITE_API_URL=https://your-backend-origin.com

# For local development you can leave this unset to use the dev proxy (/api)
# VITE_API_URL=http://localhost:5000
